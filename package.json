{
  "name": "sigil",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./config": {
      "types": "./dist/src/config.d.ts",
      "import": "./dist/src/config.js"
    },
    "./discovery": {
      "types": "./dist/src/discovery.d.ts",
      "import": "./dist/src/discovery.js"
    }
  },
  "bin": {
    "sigil": "./dist/scripts/gen-components.js",
    "sigil-dev": "./dist/scripts/dev-server.js"
  },
  "files": [
    "dist/src",
    "dist/scripts",
    "src",
    "scripts"
  ],
  "scripts": {
    "dev": "node --import tsx scripts/dev-server.ts",
    "gen:components": "node --import tsx scripts/gen-components.ts",
    "build": "tsc",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/core.test.ts test/demo-smoke.test.ts test/discovery.test.ts test/dev-server.test.ts test/tokens.test.ts",
    "test:built": "tsc && node --test dist/test/core.test.js dist/test/demo-smoke.test.js dist/test/discovery.test.js dist/test/dev-server.test.js dist/test/tokens.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
